+#else
+        .next_handoff_image_id = INVALID_IMAGE_ID,
+#endif /* RZT2H_CA55_CR52_BL2_BOOT */
+#if RZT2H_CA55_CR52_BL2_BOOT
+	},
+    {
+        .image_id = BL22_IMAGE_ID,
+
+        SET_STATIC_PARAM_HEAD(image_info, PARAM_IMAGE_BINARY, VERSION_2,
+                              image_info_t, IMAGE_ATTRIB_PLAT_SETUP),
+        .image_info.image_max_size = BL22_LIMIT - BL22_BASE,
+
+        .image_info.image_base = BL22_BASE,
+
+        .next_handoff_image_id = INVALID_IMAGE_ID,
+    }
+#else
+	}
+#endif /* RZT2H_CA55_CR52_BL2_BOOT */	
+};
+
+REGISTER_BL_IMAGE_DESCS(bl2_mem_params_descs) 							
