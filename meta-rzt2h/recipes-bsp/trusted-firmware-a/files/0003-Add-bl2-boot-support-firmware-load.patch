diff --git a/plat/renesas/rz/soc/t2h/bl2_plat_setup.c b/plat/renesas/rz/soc/t2h/bl2_plat_setup.c
index 852cb3027..2736e6cda 100644
--- a/plat/renesas/rz/soc/t2h/bl2_plat_setup.c
+++ b/plat/renesas/rz/soc/t2h/bl2_plat_setup.c
@@ -25,6 +25,20 @@
 #include <rz_soc_def.h>
 #include <rz_private.h>
 
+#include <common/tbbr/tbbr_img_def.h>
+#include <plat_tbbr_img_def.h>
+#include <common/debug.h>
+
+#if RZT2H_CA55_CR52_BL2_BOOT
+/* Key code for writing PRCR register */
+#define BSP_PRV_PRCR_KEY		(0xA500U)
+#define PRCRN1					*((volatile uint32_t *)0x80294200)
+#define PRCRS1					*((volatile uint32_t *)0x81296000)
+#define SSTPCR71				*((volatile uint32_t *)0x8129020C)
+#define CPU1HALT				*((volatile uint32_t *)0x81295010)
+
+static void bsp_copy_8byte (uintptr_t * src, uintptr_t * dst, uintptr_t bytesize);
+#endif
 
 static console_t rzt2h_bl2_console;
 
@@ -59,6 +73,95 @@ int bl2_plat_handle_post_image_load(unsigned int image_id)
 		memcpy(&params->bl33_ep_info, &bl_mem_params->ep_info,
 			sizeof(entry_point_info_t));
 		break;
+#if RZT2H_CA55_CR52_BL2_BOOT
+	case BL22_IMAGE_ID:
+	{
+		uintptr_t src = RZT2H_SPIROM_A55_R52_FW_BASE;
+		uintptr_t dst = BSP_PRV_SECTION_SECONDARY_RAM_START;
+		uintptr_t size = BL22_FW_SIZE;
+
+#if (PLAT_A551_BL2_BOOT || PLAT_A552_BL2_BOOT || PLAT_A553_BL2_BOOT)
+		/* Un-lock writing to CA55_RVBAxy registers */
+		sys_safetybase_unlock(PRCRx_SYS_CTRL);
+
+		/* Reset flag for secondary core to stop  booting */
+		mmio_write_32(SEMAR0, 0);
+#elif (PLAT_R520_BL2_BOOT || PLAT_R521_BL2_BOOT)
+		/* 
+		 * Setting Area protect register (Non-Safety and Safety)
+		 * Enables writing to the registers related to the clock generation circuit. 
+		 * Enables writing to the registers related to low power consumption and reset. 
+		 * Enables writing to the registers related to GPIO settings. 
+		 * Enables writing to the registers related to System control.
+		 */
+		PRCRN1 = BSP_PRV_PRCR_KEY | 0xF;
+		PRCRS1 = BSP_PRV_PRCR_KEY | 0xF;
+#else
+		NOTICE("Second boot core is not selected (A55/R52)\n");
+#endif
+		bsp_copy_8byte((uintptr_t*)src, (uintptr_t*)dst, size);
+
+#if PLAT_A551_BL2_BOOT
+		/* Write rebase address */
+		mmio_write_32(CA55_RVBAL1, (uint32_t)(BSP_PRV_IMAGE_INFO_BRANCH_ADDRESS & 0xFFFFFFFC));
+		mmio_write_32(CA55_RVBAH1, (uint32_t)((0) & 0xFF));
+
+		sys_a55_sw_reset();
+
+		/* Lock writing to CA55_RVBAxy registers */
+		sys_safetybase_lock(PRCRx_SYS_CTRL);
+#elif PLAT_A552_BL2_BOOT
+		/* Write rebase address */
+		mmio_write_32(CA55_RVBAL2, (uint32_t)(BSP_PRV_IMAGE_INFO_BRANCH_ADDRESS & 0xFFFFFFFC));
+		mmio_write_32(CA55_RVBAH2, (uint32_t)((0) & 0xFF));
+
+		sys_a55_sw_reset();
+
+		/* Lock writing to CA55_RVBAxy registers */
+		sys_safetybase_lock(PRCRx_SYS_CTRL);
+#elif PLAT_A553_BL2_BOOT
+		/* Write rebase address */
+		mmio_write_32(CA55_RVBAL3, (uint32_t)(BSP_PRV_IMAGE_INFO_BRANCH_ADDRESS & 0xFFFFFFFC));
+		mmio_write_32(CA55_RVBAH3, (uint32_t)((0) & 0xFF));
+
+		sys_a55_sw_reset();
+
+		/* Lock writing to CA55_RVBAxy registers */
+		sys_safetybase_lock(PRCRx_SYS_CTRL);
+#elif PLAT_R520_BL2_BOOT
+		uint32_t * dst_cpu0 = (uint32_t *) BSP_PRV_ATCM_AXIS_CR520_ADDRESS;
+
+		/* Store the instruction code to start address of the ATCM of CPU0 via AXIS interface*/
+		*dst_cpu0++ = BSP_PRV_IMAGE_INFO_BRANCH_INSTRUCTION_CR520;
+		*dst_cpu0++ = BSP_PRV_IMAGE_INFO_BRANCH_ADDRESS;
+
+		/* Reset CR52_0 and release the reset state */
+		mmio_write_32(SWRCPU0, 0x4321A502);
+#elif PLAT_R521_BL2_BOOT
+		R_BSP_MODULE_START(FSP_IP_CR52, 1U);
+
+		/* Release CR52_1 from the reset state */
+		mmio_write_32(SWRCPU1, 0x00000000);
+
+		/* Release from the slave stop state */
+		SSTPCR71 = (uint32_t) ((uintptr_t) (SSTPCR7 & ~R_SSC_SSTPCR7_AXIS1_REQ_Msk));
+
+		/* Polling ACK bit in SSTPCR */
+		FSP_HARDWARE_REGISTER_WAIT((SSTPCR7 & (1 << R_SSC_SSTPCR7_AXIS1_ACK_Pos)), 0);
+
+		uint64_t * dst_cpu1 = (uint64_t *) BSP_PRV_ATCM_AXIS_CR521_ADDRESS;
+
+		/* Store the instruction code to start address of the ATCM of CPU1 via AXIS interface */
+		*dst_cpu1++ = BSP_PRV_IMAGE_INFO_BRANCH_INSTRUCTION_CR521;
+		*dst_cpu1++ = BSP_PRV_IMAGE_INFO_BRANCH_ADDRESS;
+		__asm volatile ("DSB SY");
+
+		/* Start instruction fetch by writing 0 to CPU1HALT bit in CPU1HALT register */
+		CPU1HALT = 0x00000000;
+#endif
+	}
+		break;
+#endif		
 	default:
 		/* Do nothing in default case */
 		break;
@@ -137,7 +240,11 @@ void bl2_el3_plat_arch_setup(void)
 	};
 
 	setup_page_tables(bl2_regions, rzt2h_mmap);
-	enable_mmu_el3(0);
+#if RZT2H_CA55_CR52_BL2_BOOT
+	enable_mmu_el3(1);
+#else
+ 	enable_mmu_el3(0);
+#endif
 }
 
 void bl2_platform_setup(void)
@@ -179,3 +286,29 @@ void bl2_platform_setup(void)
 	NOTICE("BL2: PART NUMBER: 0X%x\n", sys_get_platform_part_number());
 	NOTICE("BL2: PRODUCT VERSION: 0X%x\n", sys_get_platform_product_version());
 }
+
+#if RZT2H_CA55_CR52_BL2_BOOT
+static void bsp_copy_8byte (uintptr_t * src, uintptr_t * dst, uintptr_t bytesize)
+{
+	bytesize = ((bytesize + (sizeof(uint64_t) - 1)) / sizeof(uint64_t));
+
+	__asm volatile (
+	"    MOV    x1, %0                    \n"
+	"    MOV    x2, %1                    \n"
+	"    MOV    x3, %2                    \n"
+	"    MOV    x4, #0                    \n"
+	"copy_to_dst:                         \n"
+	"    CMP    x3, x4                    \n"
+	"    B.EQ   copy_to_dst_end           \n"
+	"    LDR    x0, [x1], #8              \n"
+	"    STR    x0, [x2], #8              \n"
+	"    DSB SY                           \n"
+	"    ADD    x4, x4, #1                \n"
+	"    B.NE   copy_to_dst               \n"
+	"copy_to_dst_end:                     \n"
+	::"r" (src),
+	"r" (dst),
+	"r" (bytesize)
+	: "memory", "x0", "x1", "x2", "x3", "x4");
+}
+#endif
