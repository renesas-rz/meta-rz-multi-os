--- a/plat/renesas/rz/soc/t2h/drivers/sys.c
+++ b/plat/renesas/rz/soc/t2h/drivers/sys.c
@@ -182,3 +182,32 @@ bool sys_check_platform_core_count(void)
 
 	return res;
 }
+
+void sys_a55_sw_reset(void)
+{
+	/* Disable Write Protection */
+	sys_safetybase_unlock(PRCRx_LOW_POWER);
+#if PLAT_A551_BL2_BOOT
+	/* Release the reset state of CA55 cluster */
+	mmio_write_32(SWR55C, 0x00000000);
+
+	/* Release the reset state of each CA55_1 core */
+	mmio_write_32(SWR551, 0x00000000);
+#elif PLAT_A552_BL2_BOOT
+	/* Release the reset state of CA55 cluster */
+	mmio_write_32(SWR55C, 0x00000000);
+	
+	/* Release the reset state of each CA55_2 core */
+	mmio_write_32(SWR552, 0x00000000);
+#elif PLAT_A553_BL2_BOOT
+	/* Release the reset state of CA55 cluster */
+	mmio_write_32(SWR55C, 0x00000000);
+
+	/* Release the reset state of each CA55_3 core */
+	mmio_write_32(SWR553, 0x00000000);
+#else
+	// Do nothing
+#endif
+	/* Enable Write Protection */
+	sys_safetybase_lock(PRCRx_LOW_POWER);
+}
